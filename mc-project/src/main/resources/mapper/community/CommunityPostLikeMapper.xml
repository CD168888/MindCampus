<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mc.community.mapper.CommunityPostLikeMapper">

    <resultMap type="com.mc.community.domain.CommunityPostLike" id="CommunityPostLikeResult">
        <result property="id"    column="id"    />
        <result property="postId"    column="post_id"    />
        <result property="userId"    column="user_id"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <select id="selectLikeByPostAndUser" resultMap="CommunityPostLikeResult">
        select id, post_id, user_id, create_time
        from community_post_like
        where post_id = #{postId} and user_id = #{userId}
    </select>

    <insert id="insertLike" parameterType="com.mc.community.domain.CommunityPostLike">
        insert into community_post_like (post_id, user_id, create_time)
        values (#{postId}, #{userId}, now())
    </insert>

    <delete id="deleteLike">
        delete from community_post_like
        where post_id = #{postId} and user_id = #{userId}
    </delete>

</mapper>
